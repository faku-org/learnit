# Port the API listens on. Must match PUBLIC_API_PORT in the root .env,
# which is what the frontend calls.
PORT=3001

# Deepseek API key — get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# MongoDB connection string (default works for a local instance)
MONGO_URI=mongodb://localhost:27017

# Database name
DB_NAME=learnit

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Without these the sign-in button redirects to a Google error page instead of
# the account picker, because client_id comes through empty.
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Must be registered verbatim as an authorized redirect URI in the console.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Where the API sends the browser back after a successful login.
APP_URL=http://localhost:4321

# Signing key for session tokens. Falls back to a known dev string if unset —
# set a real random value for anything other than local development.
JWT_SECRET=
