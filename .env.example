# Frontend environment. Copy to .env — Astro loads it from the project root.
# The API has its own separate file: see api/.env.example.
#
# Only PUBLIC_-prefixed vars reach the browser, so never put a secret here.

# Port the API is listening on. Must match PORT in api/.env.
# The frontend builds every API URL as http://localhost:<this>.
PUBLIC_API_PORT=3001
